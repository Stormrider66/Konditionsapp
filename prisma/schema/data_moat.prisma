/// Pre-computed monthly/yearly nutrition summary ("Wrapped")
model NutritionWrapped {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Period
  periodType String // MONTHLY | YEARLY
  month      Int? // 1-12 for monthly
  year       Int

  // Pre-computed summary stats (JSON for flexibility)
  stats Json

  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([clientId, periodType, year, month])
  @@index([clientId])
  @@index([periodType, year])
}

