// NUTRITION domain models & enums.
// Auto-grouped from schema.prisma — keep new declarations here.

// ==================== NUTRITION TIMING SYSTEM ====================

/// Athlete dietary preferences for nutrition guidance personalization
model DietaryPreferences {
  id       String @id @default(uuid())
  clientId String @unique

  // Dietary style
  dietaryStyle String? // OMNIVORE | VEGETARIAN | VEGAN | PESCATARIAN | FLEXITARIAN

  // Allergies & intolerances (JSON arrays for flexibility)
  allergies    Json? // ["NUTS", "SHELLFISH", "DAIRY", "GLUTEN", "SOY", "EGGS", "FISH"]
  intolerances Json? // ["LACTOSE", "FRUCTOSE", "HISTAMINE"]

  // Food dislikes (for suggestion filtering)
  dislikedFoods Json? // ["oatmeal", "fish", "beans"]

  // Preferences
  preferLowFODMAP       Boolean @default(false)
  preferWholeGrain      Boolean @default(true)
  preferSwedishFoods    Boolean @default(true) // Prioritize Swedish food suggestions
  enhancedMacroAnalysis Boolean @default(false)

  // Food-scan personalized memory
  memoryEnabled         Boolean   @default(true)
  memoryLastExtractedAt DateTime?

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

/// Athlete nutrition goals (weight, body composition, macro preferences)
model NutritionGoal {
  id       String @id @default(uuid())
  clientId String @unique

  // Weight goals
  goalType       String // WEIGHT_LOSS | WEIGHT_GAIN | MAINTAIN | BODY_RECOMP
  targetWeightKg Float?
  weeklyChangeKg Float? // Target weekly change: 0.25, 0.5, 0.75 kg/week
  targetDate     DateTime?

  // Body composition goals
  targetBodyFatPercent Float?

  // Macro preference (overrides sport-based defaults)
  macroProfile String? // BALANCED | HIGH_PROTEIN | LOW_CARB | ENDURANCE | STRENGTH | KETO | CUSTOM

  // Custom macro percentages (0-100, must sum to 100 when all provided)
  customProteinPercent Float?
  customCarbsPercent   Float?
  customFatPercent     Float?

  // Activity level (for TDEE calculation)
  activityLevel String @default("ACTIVE") // SEDENTARY | LIGHTLY_ACTIVE | ACTIVE | VERY_ACTIVE | ATHLETE

  // Custom protein target (g per kg body weight, overrides calculated value)
  customProteinPerKg Float?

  // Custom BMR (kcal) from bio-impedance screening or other measurement
  // Overrides the calculated Mifflin-St Jeor estimate for TDEE-based guidance
  customBmrKcal Int?

  // Display preferences
  showMacroTargets Boolean @default(true)
  showHydration    Boolean @default(true)

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// ==================== MEAL LOGGING SYSTEM ====================

/// Meal type enum for categorizing meals
enum MealType {
  BREAKFAST
  MORNING_SNACK
  LUNCH
  AFTERNOON_SNACK
  PRE_WORKOUT
  POST_WORKOUT
  DINNER
  EVENING_SNACK
}

/// MealLog for tracking daily food intake
model MealLog {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Meal info
  date        DateTime @db.Date
  mealType    MealType
  time        String? // "08:30", "12:00" etc.
  description String // "Havregrynsgröt med banan och nötter"

  // Macros (optional - can be estimated or precise)
  calories     Int?
  proteinGrams Float?
  carbsGrams   Float?
  fatGrams     Float?
  fiberGrams   Float?

  // Enhanced macro subcategories (optional)
  saturatedFatGrams       Float?
  monounsaturatedFatGrams Float?
  polyunsaturatedFatGrams Float?
  sugarGrams              Float?
  complexCarbsGrams       Float?
  isCompleteProtein       Boolean?

  // Hydration (optional)
  waterMl Int?

  // Meal quality indicators
  isHighProtein Boolean @default(false) // 20g+ protein
  isPreWorkout  Boolean @default(false)
  isPostWorkout Boolean @default(false)

  // Photo (optional - stored as URL)
  photoUrl String?

  notes String?

  // Individual food items (from AI photo/voice analysis)
  items MealFoodItem[]

  // Optional link to a generated performance meal guide slot. All capture
  // flows (photo, voice, text, ingredient builder) can attach here so planned
  // vs eaten charts stay unified.
  plannedMealId              String?
  plannedMeal                NutritionPlannedMeal? @relation(fields: [plannedMealId], references: [id], onDelete: SetNull)
  plannedMealMatchSource     String? // AUTO | MANUAL
  plannedMealMatchConfidence Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, date])
  @@index([date])
  @@index([plannedMealId])
}

/// Captures the delta between what the food-scan AI first produced and what the
/// athlete actually saved. Used to weight "corrections" higher than passive logs
/// when building personalized food memory (Phase 4 fingerprint cron).
model FoodScanCorrection {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  mealLogId String? // null if the scan was refined/edited but never saved as a meal

  aiItemsJson    Json // items array the API returned (after second pass + portion calibration)
  finalItemsJson Json // items array the user actually saved

  correctionType String // 'NAME' | 'GRAMS' | 'ADDED_ITEM' | 'REMOVED_ITEM' | 'MULTIPLE'

  aiConfidence      Float? // confidence the AI reported on its final analysis
  wentThroughRefine Boolean @default(false) // true if the user used the refine flow before saving

  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
  @@index([correctionType])
}

/// Individual food item within a meal.
///
/// Populated by two flows:
/// 1. AI photo/voice analysis (foodId null, name from AI)
/// 2. Manual ingredient builder (foodId set when user picked a Food from
///    Livsmedelsverket; macro fields are computed from Food per-100g × grams).
///
/// Edit-meal hydration loads these items back into the ingredient builder.
model MealFoodItem {
  id        String  @id @default(cuid())
  mealLogId String
  mealLog   MealLog @relation(fields: [mealLogId], references: [id], onDelete: Cascade)

  // Reference Food row when the item was picked from the food database.
  // Null when the user typed a free-text ingredient or AI invented the name.
  foodId String?
  food   Food?   @relation(fields: [foodId], references: [id], onDelete: SetNull)

  // Food identity
  name           String // "Kyckling" — Swedish name from AI or Food.nameSv
  normalizedName String // Lowercase, trimmed — for aggregation queries
  category       String? // PROTEIN | CARB | FAT | VEGETABLE | FRUIT | DAIRY | GRAIN | BEVERAGE | OTHER

  // Portion
  estimatedGrams     Float
  portionDescription String? // "1 kycklingfilé", "2 dl"

  // Macros (per this item)
  calories     Float
  proteinGrams Float
  carbsGrams   Float
  fatGrams     Float
  fiberGrams   Float @default(0)

  // Enhanced subcategories (optional)
  saturatedFatGrams       Float?
  monounsaturatedFatGrams Float?
  polyunsaturatedFatGrams Float?
  sugarGrams              Float?
  complexCarbsGrams       Float?
  isCompleteProtein       Boolean?
  proteinSource           String? // ANIMAL | PLANT | MIXED | UNKNOWN

  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  @@index([mealLogId])
  @@index([normalizedName])
  @@index([foodId])
}

/// Athlete-owned reusable recipe template. This is intentionally separate
/// from MealLog so saved recipes do not pollute meal history.
model NutritionRecipe {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  baseServings Float   @default(1)
  source       String  @default("MANUAL") // MANUAL | SCAN | MEAL_COPY

  items NutritionRecipeIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, updatedAt])
  @@index([clientId, name])
}

/// Ingredient rows for a reusable recipe template. Nutrients are cached per
/// 100g, matching Food and IngredientBuilder so scaling stays exact.
model NutritionRecipeIngredient {
  id       String          @id @default(cuid())
  recipeId String
  recipe   NutritionRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  foodId String?
  food   Food?   @relation(fields: [foodId], references: [id], onDelete: SetNull)

  name           String
  normalizedName String
  category       String?
  grams          Float

  caloriesPer100g Float @default(0)
  proteinPer100g  Float @default(0)
  carbsPer100g    Float @default(0)
  fatPer100g      Float @default(0)
  fiberPer100g    Float @default(0)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  @@index([recipeId])
  @@index([foodId])
  @@index([normalizedName])
}

/// Athlete-facing 7-day performance meal guide. Generated from deterministic
/// macro targets, schedule/BIA/Garmin context, and optional AI meal wording.
model NutritionPerformancePlan {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title     String
  status    String   @default("ACTIVE") // ACTIVE | ARCHIVED
  source    String   @default("PERFORMANCE_MEAL_GUIDE")
  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  goalSnapshot      Json
  contextSnapshot   Json?
  generatedSnapshot Json?

  days NutritionPlanDay[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, status, startDate, endDate])
  @@index([status])
}

/// One generated nutrition day within a performance meal guide.
model NutritionPlanDay {
  id       String @id @default(cuid())
  planId   String
  plan     NutritionPerformancePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  date    DateTime @db.Date
  dayType String // GAME | PRACTICE | HARD_PRACTICE | DOUBLE | REST | RECOVERY | TRAVEL

  caloriesKcal Int
  proteinG     Int
  carbsG       Int
  fatG         Int
  hydrationMl  Int

  weightKg Float?
  bmrKcal  Int?

  scheduleSnapshot Json?
  garminSnapshot   Json?
  biaSnapshot      Json?
  adaptationNotes  String?

  meals NutritionPlannedMeal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, date])
  @@index([clientId, date])
  @@index([dayType])
}

/// A concrete planned meal slot with portions, macros, timing intent, and swaps.
model NutritionPlannedMeal {
  id    String           @id @default(cuid())
  dayId String
  day   NutritionPlanDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  mealType MealType
  time     String?
  title    String
  description String?

  timingRole String @default("REGULAR") // REGULAR | PRE_WORKOUT | POST_WORKOUT | GAME_FUEL | RECOVERY
  explanation String?

  portionSummary Json

  recipeTitle       String?
  recipeSummary     String?
  recipeServings    Float   @default(1)
  recipePrepMinutes Int?
  recipeCookMinutes Int?
  recipeIngredients Json?
  recipeSteps       Json?
  recipeTips        Json?
  recipeSource      String  @default("TEMPLATE") // TEMPLATE | AI
  recipePrompt      String?
  recipeUpdatedAt   DateTime?

  caloriesKcal Int
  proteinG     Float
  carbsG       Float
  fatG         Float
  fiberG       Float?

  sortOrder Int @default(0)

  // Athlete skipped this meal; its macros are redistributed across the
  // remaining un-logged meals so the day's target is still covered.
  skipped Boolean @default(false)

  options NutritionPlannedMealOption[]
  mealLogs MealLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dayId, sortOrder])
  @@index([mealType])
}

/// Equivalent swaps for a planned meal slot.
model NutritionPlannedMealOption {
  id            String               @id @default(cuid())
  plannedMealId String
  plannedMeal   NutritionPlannedMeal @relation(fields: [plannedMealId], references: [id], onDelete: Cascade)

  title String
  description String?
  portionSummary Json

  caloriesKcal Int
  proteinG     Float
  carbsG       Float
  fatG         Float
  fiberG       Float?

  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  @@index([plannedMealId, sortOrder])
}

/// Reference food database — primarily Livsmedelsverket (Swedish food agency),
/// but `source` is left open for future imports (Open Food Facts, custom user
/// foods, etc.). All nutrient fields are per 100g; the meal-side code
/// multiplies by grams when building MealFoodItem rows.
model Food {
  id String @id @default(cuid())

  // External identity (e.g. Livsmedelsverket nummer). Allows idempotent re-imports.
  source     String // LIVSMEDELSVERKET | OPENFOODFACTS | CUSTOM
  externalId String? // Source-specific ID (Livsmedelsverket: livsmedelsnummer)

  // Names
  nameSv     String
  nameEn     String?
  searchName String // Lowercase nameSv — indexed for ILIKE typeahead

  category String? // PROTEIN | CARB | FAT | VEGETABLE | FRUIT | DAIRY | GRAIN | BEVERAGE | OTHER

  // Nutrient values per 100 g
  caloriesPer100g Float
  proteinPer100g  Float
  carbsPer100g    Float
  fatPer100g      Float
  fiberPer100g    Float?

  saturatedFatPer100g       Float?
  monounsaturatedFatPer100g Float?
  polyunsaturatedFatPer100g Float?
  sugarPer100g              Float?
  proteinSource             String? // ANIMAL | PLANT | MIXED | UNKNOWN
  isCompleteProtein         Boolean?

  // Surface ranking. Bumped by the search API when an item is picked.
  popularity Int @default(0)

  items       MealFoodItem[]
  recipeItems NutritionRecipeIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, externalId])
  @@index([searchName])
  @@index([popularity])
}
