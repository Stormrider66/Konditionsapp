  seasonName String // "Spring 2025", "Fall Marathon Build"
  startDate  DateTime
  endDate    DateTime

  races Race[]

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
