  monthlyHours            Json @default("[]") // [jan, feb, ..., dec] in hours
  monthlyZoneDistribution Json @default("[]") // [{z1, z2, z3, z4, z5}, ...] per month

  // Breakdown by type
  workoutsByType Json @default("{}")
  hoursByType    Json @default("{}") // { "RUNNING": 450, "CYCLING": 200 }

