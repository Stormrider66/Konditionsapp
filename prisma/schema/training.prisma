model RaceFuelingPlan {
  id          String @id @default(uuid())
  clientId    String
  createdById String?
  testId      String?
  raceId      String?
  programId   String?

  sport SportType
  name  String?

  // Race target
  distanceKm       Float?
  durationMinutes  Float?
  targetSpeedKmh   Float?
  targetPowerWatts Float?
  targetPaceMinKm  Float?
  raceDate         DateTime?

  // Calculated demand and practical recommendation
  estimatedCarbDemandGPerHour Float?
  estimatedCarbDemandTotalG   Float?
  recommendedCarbsGPerHour    Float?
  recommendedCarbsTotalG      Float?
  confidence                  String @default("LOW")

  // Structured scenarios and assumptions for Swedish UI/report rendering
  scenarios   Json?
  assumptions Json?
  warnings    Json?
  productPlan Json?

  // Coach/athlete workflow
  status        String @default("DRAFT") // DRAFT, APPROVED, ARCHIVED
  coachNotes    String? @db.Text
  athleteNotes  String? @db.Text
  approvedAt    DateTime?

  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?            @relation("RaceFuelingPlanCreator", fields: [createdById], references: [id], onDelete: SetNull)
  test      Test?            @relation(fields: [testId], references: [id], onDelete: SetNull)
  race      Race?            @relation(fields: [raceId], references: [id], onDelete: SetNull)
