// CARDIO domain models & enums.
// Auto-grouped from schema.prisma — keep new declarations here.

// ============================================
// CARDIO SESSION LIBRARY
// ============================================

/// Coach-owned cardio session template
model CardioSession {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text

  // Session configuration
  sport SportType @default(RUNNING)

  // Segment data (JSON for flexibility)
  segments Json // [{type, duration, distance, pace, zone, notes}]

  // Computed totals
  totalDuration Int? // seconds
  totalDistance Float? // meters
  avgZone       Float?

  // Ownership
  coachId  String
  coach    User    @relation("CoachCardioSessions", fields: [coachId], references: [id], onDelete: Cascade)
  teamId   String?
  team     Team?   @relation("TeamCardioSessions", fields: [teamId], references: [id], onDelete: SetNull)
  isPublic Boolean @default(false)

  // Library metadata for fast filtering across seasons and teams
  trainingYear Int?

  // Tags for filtering
  tags String[] @default([])

  // Assignments
  assignments CardioSessionAssignment[]

  // Focus Mode logs
  sessionLogs CardioSessionLog[]

  // Team workout broadcasts
  teamWorkoutBroadcasts TeamWorkoutBroadcast[]

  // Voice workout creation
  voiceWorkoutSessions VoiceWorkoutSession[] @relation("CardioSessionVoiceWorkouts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId])
  @@index([teamId])
  @@index([trainingYear])
  @@index([teamId, trainingYear])
  @@index([sport])
  @@index([isPublic])
}

/// Assignment of cardio session to athlete
model CardioSessionAssignment {
  id String @id @default(uuid())

  session   CardioSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String

  athlete   Client @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  athleteId String

  // Assignment details
  assignedDate DateTime @db.Date
  assignedBy   String // Coach user ID
  notes        String?  @db.Text

  // Scheduling fields (optional appointment info)
  startTime          String? // "HH:mm" format
  endTime            String? // "HH:mm" format
  locationId         String? // FK to Location
  locationName       String? // Fallback text if no Location record
  scheduledBy        String? // Coach who scheduled (if different from assignedBy)
  responsibleCoachId String? // Coach responsible for session (shows in their calendar)

  // Calendar integration
  calendarEventId String? // Link to created CalendarEvent

  // Garmin integration
  garminWorkoutId String? // ID returned by Garmin after push
  garminPushedAt  DateTime? // Timestamp of last push

  // Status tracking
  status      AssignmentStatus @default(PENDING)
  completedAt DateTime?

  // Logged workout data
  actualDuration Int? // seconds
  actualDistance Float? // meters
  avgHeartRate   Int?
  actualSegments Json? // Logged segment data

  // Team broadcast tracking (null if individual assignment)
  teamBroadcastId String?
  teamBroadcast   TeamWorkoutBroadcast? @relation(fields: [teamBroadcastId], references: [id], onDelete: SetNull)

  // Relations for scheduling
  location         Location?      @relation("CardioAssignmentLocation", fields: [locationId], references: [id])
  calendarEvent    CalendarEvent? @relation("CardioAssignmentCalendar", fields: [calendarEventId], references: [id])
  responsibleCoach User?          @relation("CardioAssignmentResponsibleCoach", fields: [responsibleCoachId], references: [id], onDelete: SetNull)

  // Live Voice Coaching Sessions
  liveVoiceCoachingSessions LiveVoiceCoachingSession[] @relation("AssignmentLiveVoiceSessions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, athleteId, assignedDate])
  @@index([sessionId])
  @@index([athleteId])
  @@index([assignedDate])
  @@index([status])
  @@index([teamBroadcastId])
  @@index([locationId])
  @@index([startTime])
  @@index([calendarEventId])
  @@index([responsibleCoachId])
}

/// Cardio session log - tracks Focus Mode execution
model CardioSessionLog {
  id String @id @default(uuid())

  session   CardioSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String

  athlete   Client @relation("AthleteCardioLogs", fields: [athleteId], references: [id], onDelete: Cascade)
  athleteId String

  // Optional link to assignment if this was assigned
  assignmentId String?

  // Execution timing
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  // Overall session metrics
  status         AssignmentStatus @default(PENDING)
  actualDuration Int? // total seconds
  actualDistance Float? // total km
  avgHeartRate   Int?
  maxHeartRate   Int?
  avgPower       Int? // average watts (power-based equipment)
  maxPower       Int? // peak watts

  // Segment logs
  segmentLogs CardioSegmentLog[]

  // Session feedback
  sessionRPE    Int? // 1-10
  notes         String? @db.Text
  focusModeUsed Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([athleteId])
  @@index([startedAt])
  @@index([status])
}

/// Per-segment log within a Cardio session
model CardioSegmentLog {
  id String @id @default(uuid())

  cardioSessionLog   CardioSessionLog @relation(fields: [cardioSessionLogId], references: [id], onDelete: Cascade)
  cardioSessionLogId String

  segmentIndex Int
  segmentType  CardioSegmentType

  // Planned values (copied from session definition)
  plannedDuration Int? // seconds
  plannedDistance Float? // km
  plannedPace     Int? // sec/km
  plannedZone     Int? // 1-5
  plannedCalories Int? // kcal target (airbike/rower intervals)
  plannedPower    Int? // watts (absolute target, or the resolved value of a relative target)

  // Actual values logged
  actualDuration Int? // seconds
  actualDistance Float? // km
  actualPace     Int? // sec/km
  actualAvgHR    Int?
  actualMaxHR    Int?
  actualAvgPower Int? // average watts — the benchmark/opener's value anchors relative % targets
  actualMaxPower Int? // peak watts
  actualCalories Int? // kcal burned (machine-measured delta, or manually entered)

  // Status
  completed Boolean @default(false)
  skipped   Boolean @default(false)
  notes     String?

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cardioSessionLogId])
  @@index([segmentIndex])
}

enum CardioSegmentType {
  WARMUP
  COOLDOWN
  INTERVAL
  STEADY
  RECOVERY
  HILL
  DRILLS
}
