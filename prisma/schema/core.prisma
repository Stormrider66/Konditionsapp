  modifiedCalendarEvents CalendarEvent[]       @relation("ModifiedCalendarEvents")
  calendarChanges        CalendarEventChange[] @relation("CalendarChanges")
  createdTeamEvents      TeamEvent[]           @relation("CreatedTeamEvents")
  teamCoachAssignments   TeamCoachAssignment[] @relation("TeamCoachAssignments")
  createdDrills          TeamDrill[]           @relation("CreatedDrills")
