/// Public profile for coaches in the marketplace
model CoachProfile {
  id     String @id @default(uuid())
  userId String @unique
  slug   String @unique // URL: /coaches/john-doe

  // Public profile
  headline      String? // "Marathon Coach & Exercise Physiologist"
  bio           String? @db.Text
  imageUrl      String?
  coverImageUrl String?

  // Specializations
  specialties     SportType[] // RUNNING, CYCLING, TRIATHLON, etc.
  methodologies   String[] // Polarized, Norwegian, Canova, etc.
  experienceYears Int?
  credentials     String[] // Certifications
  dashboardMode   String? // "TEAM", "PT", "GYM" — null = auto-detect

  // Marketplace settings
  isPublic           Boolean @default(false)
  isVerified         Boolean @default(false)
  isAcceptingClients Boolean @default(true)

  // Location & availability
  location  String? // "Stockholm, Sweden"
  timezone  String? // "Europe/Stockholm"
  languages String[] @default(["sv", "en"])

  // Stats (calculated, updated by triggers/cron)
  totalClients  Int    @default(0)
  activeClients Int    @default(0)
  averageRating Float?
  reviewCount   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews CoachReview[]

  @@index([slug])
  @@index([isPublic, isAcceptingClients])
  @@index([isVerified])
}

/// Request from athlete to connect with a coach
model CoachRequest {
  id              String @id @default(uuid())
  athleteClientId String
  coachUserId     String
  businessId      String? // When set, this is an intra-business request

  initiatedBy   String             @default("ATHLETE") // "ATHLETE" or "COACH"
  status        CoachRequestStatus @default(PENDING)
  message       String?            @db.Text // Intro message from whoever initiated
  coachResponse String?            @db.Text

  requestedAt DateTime  @default(now())
  respondedAt DateTime?
  expiresAt   DateTime // Auto-expire after 14 days

  athlete  Client    @relation("AthleteCoachRequests", fields: [athleteClientId], references: [id], onDelete: Cascade)
  coach    User      @relation("CoachRequestsReceived", fields: [coachUserId], references: [id], onDelete: Cascade)
  business Business? @relation("BusinessCoachRequests", fields: [businessId], references: [id], onDelete: SetNull)

  @@unique([athleteClientId, coachUserId])
  @@index([coachUserId, status])
  @@index([expiresAt])
  @@index([athleteClientId])
  @@index([businessId, status])
}

/// Active coaching relationship between athlete and coach
model CoachAgreement {
  id              String @id @default(uuid())
  athleteClientId String
  coachUserId     String
  businessId      String? // Business context (null = marketplace)
  assignedByUserId String? // Who assigned (null = athlete-initiated)

  status    CoachAgreementStatus @default(ACTIVE)
  startedAt DateTime             @default(now())
  endedAt   DateTime?
  endReason String?

  // Revenue share tracking
  revenueSharePercent   Float     @default(75) // Coach gets 75%
  revenueShareStartDate DateTime? // When share kicks in (next billing)

  // What happens to existing program
  programAction String? // 'KEPT', 'MODIFIED', 'REPLACED'

  athlete    Client    @relation("AthleteCoachAgreements", fields: [athleteClientId], references: [id], onDelete: Cascade)
  coach      User      @relation("CoachAgreementsAsCoach", fields: [coachUserId], references: [id], onDelete: Cascade)
  business   Business? @relation("BusinessCoachAgreements", fields: [businessId], references: [id], onDelete: SetNull)
  assignedBy User?     @relation("CoachAgreementsAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@unique([athleteClientId, coachUserId])
  @@index([coachUserId, status])
  @@index([athleteClientId])
  @@index([businessId, status])
}

/// Earnings from athlete subscriptions (coach revenue share)
model CoachEarnings {
  id              String @id @default(uuid())
  coachUserId     String
  athleteClientId String
  subscriptionId  String

  periodStart DateTime
  periodEnd   DateTime

  totalAmount    Int   // Total payment in öre (cents)
  coachAmount    Int   // Coach's share
  platformAmount Int   // Platform's share
  sharePercent   Float // Share % at time of payment

  status    String    @default("PENDING") // PENDING, PAID_OUT
  paidOutAt DateTime?

  createdAt DateTime @default(now())

  coach   User   @relation("CoachEarnings", fields: [coachUserId], references: [id])
  athlete Client @relation("AthleteCoachEarnings", fields: [athleteClientId], references: [id], onDelete: Cascade)

  @@index([coachUserId, status])
  @@index([periodStart])
  @@index([athleteClientId])
}

/// Tracks processed Stripe webhook events for idempotency and auditing
model StripeWebhookEvent {
  id        String   @id // Stripe event ID (evt_xxx) - natural key for deduplication
  type      String // Event type (e.g. "checkout.session.completed")
  handled   Boolean  @default(false)
  message   String? // Handler result message
  metadata  Json? // Event metadata snapshot for debugging
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

