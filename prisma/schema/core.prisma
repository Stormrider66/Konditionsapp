  email     String     @unique
  name      String
  role      UserRole   @default(COACH)
  adminRole AdminRole? // Admin-specific role for admin panel access
  language  String     @default("sv") // "sv" or "en"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Existing relations
  tests   Test[]
  clients Client[]
  teams   Team[]

  // New relations for training programs
  coachPrograms    TrainingProgram[] @relation("CoachPrograms")
  coachAthletePlans AthletePlan[]    @relation("CoachAthletePlans")
  coachTeamPlans    TeamPlan[]       @relation("CoachTeamPlans")
  createdRaceFuelingPlans RaceFuelingPlan[] @relation("RaceFuelingPlanCreator")
