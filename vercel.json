{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["arn1"],
  "functions": {
    "app/api/integrations/garmin/webhook/route.ts": {
      "maxDuration": 60
    },
    "app/api/slack/events/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron/operator/**/*.ts": {
      "maxDuration": 120
    }
  },
  "headers": [
    {
      "source": "/:path*.(js|css|woff|woff2|ttf|otf|eot|ico|svg|png|jpg|jpeg|gif|webp|avif)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/poll-research",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/poll-program-generation",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/process-daily-metrics",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/reset-budgets",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/calculate-acwr",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/injury-digest",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/mental-prep",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/morning-briefings",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/preworkout-nudges",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/pattern-detection",
      "schedule": "0 5,17 * * *"
    },
    {
      "path": "/api/cron/post-workout-checkins",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/milestone-detection",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/coach-alerts",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/expire-trials",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/trial-warnings",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/reset-ai-usage",
      "schedule": "5 0 1 * *"
    },
    {
      "path": "/api/cron/auto-optimize",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/link-workouts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/sync-oura",
      "schedule": "0 4 * * *"
    },

    {
      "path": "/api/cron/operator/platform-health",
      "schedule": "7,22,37,52 * * * *"
    },
    {
      "path": "/api/cron/operator/support",
      "schedule": "13,43 * * * *"
    },
    {
      "path": "/api/cron/operator/cost-guardian",
      "schedule": "11 * * * *"
    },
    {
      "path": "/api/cron/operator/churn-predictor",
      "schedule": "17 6 * * *"
    },
    {
      "path": "/api/cron/operator/daily-brief",
      "schedule": "23 7 * * *"
    },
    {
      "path": "/api/cron/operator/onboarding",
      "schedule": "29 9 * * *"
    },
    {
      "path": "/api/cron/operator/data-quality",
      "schedule": "37 4 * * *"
    },
    {
      "path": "/api/cron/operator/compliance",
      "schedule": "41 5 * * *"
    },
    {
      "path": "/api/cron/operator/business-intel",
      "schedule": "19 8 * * 1"
    },
    {
      "path": "/api/cron/operator/feature-curator",
      "schedule": "31 2 * * 0"
    },
    {
      "path": "/api/cron/operator/marketing",
      "schedule": "17 15 * * 5"
    },
    {
      "path": "/api/cron/operator/competitor-intel",
      "schedule": "47 10 * * 5"
    },
    {
      "path": "/api/cron/operator/job-worker",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/operator/fx-refresh",
      "schedule": "13 3 * * 1"
    }
  ]
}
